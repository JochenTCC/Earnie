# earnie_env/config/.env (Prod/Docker) bzw. ./.env (lokale Dev – Legacy-Fallback)
# Kopiere diese Datei nach earnie_env/config/.env und fülle die Werte aus.
LOXONE_USER="name-des-benutzers-in-der-loxone"
LOXONE_PASS="Passwort-des-benutzers-in-der-loxone"
LOXONE_IP=192.168.178.1

# Persistenz-Wurzel (Standard: earnie_env → …/config und …/runtime)
# EARNIE_ENV_PATH=\\YOUR-NAS\docker\earnie

# Config-Verzeichnis (Standard: earnie_env/config; enthält config.json, Sidecars, .env, uploads/)
# EARNIE_CONFIG_PATH=\\YOUR-NAS\docker\earnie\config

# Laufzeitdaten (Standard: earnie_env/runtime; oder abgeleitet aus EARNIE_ENV_PATH)
# EARNIE_RUNTIME_PATH=\\YOUR-NAS\docker\earnie\runtime

# Maschinenspezifische Einstellungen (Standard: {runtime}/local_settings.json)
# EARNIE_LOCAL_SETTINGS_PATH=earnie_env/runtime/local_settings.json
