{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: main.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Streamlit app.py",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/app.py",
        "--server.port",
        "8501"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Zip all .py files",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/zip_py_files.py",
      "args": [
        "--output",
        "${workspaceFolder}/python_sources.zip",
        "--exclude",
        "merge-logs.py",
        "--exclude",
        "zip_py_files.py"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
